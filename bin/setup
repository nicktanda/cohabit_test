#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do
  # This script is a way to set up or update your development environment automatically.
  # This script is idempotent, so that you can run it at any time and get an expectable outcome.
  # Add necessary setup steps to this file.

  puts "== Installing dependencies =="
  system! "gem install bundler --conservative"
  system("bundle check") || system!("bundle install")

  puts "\n== Setting up environment configuration =="
  unless File.exist?(".env")
    # Auto-detect database settings
    db_host = "localhost"
    db_username = ENV['USER'] || "postgres"  # Use current user or postgres as fallback
    db_password = ""

    # Check if PostgreSQL is running and try to connect with common defaults
    can_connect = false

    # Try current user first
    if system("psql -h localhost -U #{db_username} -c '\\q' 2>/dev/null")
      can_connect = true
      puts "✓ Can connect to PostgreSQL with username: #{db_username}"
    elsif system("psql -h localhost -U postgres -c '\\q' 2>/dev/null")
      # Try postgres user if current user doesn't work
      db_username = "postgres"
      can_connect = true
      puts "✓ Can connect to PostgreSQL with username: postgres"
    else
      puts "⚠ Could not auto-detect PostgreSQL connection."
      puts "Using default settings (username: #{db_username})"
      puts "You may need to adjust .env after setup if database connection fails."
    end

    # Create .env file with detected settings
    File.open(".env", "w") do |file|
      file.puts "# Auto-generated database configuration"
      file.puts "DATABASE_HOST=#{db_host}"
      file.puts "DATABASE_USERNAME=#{db_username}"
      file.puts "DATABASE_PASSWORD=#{db_password}"
      file.puts ""
      file.puts "# Rails configuration"
      file.puts "RAILS_MAX_THREADS=5"
    end

    puts "Created .env file with:"
    puts "  DATABASE_HOST=#{db_host}"
    puts "  DATABASE_USERNAME=#{db_username}"
    puts "  DATABASE_PASSWORD=(empty)"
  else
    puts ".env file already exists, skipping..."
  end

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  puts "\n== Restarting application server =="
  system! "bin/rails restart"

  puts "\n=========================================="
  puts "Setup complete!"
  puts "=========================================="
  puts "To start the application, run:"
  puts "  rails server"
  puts ""
  puts "Then visit: http://localhost:3000"
  puts "=========================================="
end
